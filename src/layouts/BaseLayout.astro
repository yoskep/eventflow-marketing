---
import '@/styles/global.css';
import TrackingEvents from '@/components/analytics/TrackingEvents.astro';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const gaId = import.meta.env.GA_MEASUREMENT_ID;
---

<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="theme-color" content="#1a2744" />

    <!-- Google Search Console verification — uncomment and add your code -->
    <!-- <meta name="google-site-verification" content="YOUR_VERIFICATION_CODE" /> -->
    <!--
      GSC Setup:
      1. Go to https://search.google.com/search-console/
      2. Add property → URL prefix → https://eventflow.co.il
      3. Choose "HTML tag" verification method
      4. Copy the content value and paste it above, then uncomment the meta tag
      5. Deploy and click Verify in GSC
    -->

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="192x192" href="/icons/icon-192.png" />

    <slot name="head" />

    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
        <script define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body class={`font-heebo bg-brand-cream text-brand-primary min-h-screen ${className ?? ''}`}>
    <slot />
    <TrackingEvents />
  </body>
</html>

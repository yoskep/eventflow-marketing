---
const painPoints = [
  {
    icon: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>`,
    text: 'הודעות בוואטסאפ מתערבבות עם לידים, ספקים ולקוחות — בלי שום סדר',
  },
  {
    icon: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
    text: 'אקסלים ומסמכים מפוזרים בכל מקום. אי אפשר למצוא כלום כשצריך',
  },
  {
    icon: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    text: 'ליד חם נשכח כי לא היה תזכורת? כסף שנשאר על השולחן',
  },
  {
    icon: `<svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`,
    text: 'מעקב תשלומים ידני — מי שילם, מי חייב, מתי הפקדון?',
  },
];
---

<section class="py-20 bg-brand-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14 animate-fade-in-up">
      <h2 class="text-3xl sm:text-4xl font-bold text-brand-primary mb-4">מכירים את זה?</h2>
      <p class="text-lg text-gray-600 max-w-xl mx-auto">הבעיות שכל ספק אירועים מתמודד איתן — יום יום</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {painPoints.map((item) => (
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="text-red-400 mb-4" set:html={item.icon} />
          <p class="text-brand-primary font-medium leading-relaxed">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

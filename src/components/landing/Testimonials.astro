---
const testimonials = [
  {
    name: 'דני כהן',
    role: 'צלם אירועים, תל אביב',
    text: 'מאז שעברתי ל-EventFlow אני חוסך לפחות שעתיים ביום על מעקבים ותשלומים. הלקוחות מקבלים הצעת מחיר מקצועית תוך דקה.',
    initials: 'ד',
  },
  {
    name: 'מירב לוי',
    role: 'DJ ומנחת אירועים, חיפה',
    text: 'סוף סוף מערכת שמבינה את עולם האירועים בארץ. הגלריות מרשימות את הלקוחות, והאוטומציות חוסכות לי טעויות.',
    initials: 'מ',
  },
  {
    name: 'אורן אברהם',
    role: 'חברת הפקות, ירושלים',
    text: 'עם EventFlow עברנו מ-3 אקסלים ו-5 קבוצות וואטסאפ למערכת אחת שעובדת. ההמרות שלנו עלו ב-40%.',
    initials: 'א',
  },
];

const stars = [1, 2, 3, 4, 5];
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14 animate-fade-in-up">
      <div class="inline-flex items-center gap-2 bg-brand-gold/10 text-brand-gold px-4 py-1.5 rounded-full text-sm font-medium mb-4">
        ספקים ממליצים
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold text-brand-primary">ספקים כמוכם כבר משתמשים</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <div class="bg-brand-cream rounded-2xl p-8 border border-gray-100 hover:shadow-md transition-shadow">
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {stars.map(() => (
              <svg class="w-5 h-5 text-brand-gold" viewBox="0 0 24 24" fill="currentColor">
                <path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            ))}
          </div>

          <p class="text-gray-700 leading-relaxed mb-6">"{t.text}"</p>

          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full gradient-gold flex items-center justify-center text-brand-primary font-bold text-sm flex-shrink-0">
              {t.initials}
            </div>
            <div>
              <div class="font-bold text-brand-primary text-sm">{t.name}</div>
              <div class="text-gray-500 text-xs">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

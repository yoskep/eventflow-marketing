---
const features = [
  {
    icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" /></svg>`,
    title: 'ניהול לידים חכם',
    desc: 'צפו בכל הלידים בלוח קנבאן אינטואיטיבי. עקבו אחרי כל פנייה, מהרגע שנכנסה ועד הסגירה.',
  },
  {
    icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
    title: 'הצעות מחיר מקצועיות',
    desc: 'צרו הצעות מחיר מדהימות תוך שניות. תבניות מוכנות, מספור אוטומטי, ושליחה ישירה ללקוח.',
  },
  {
    icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>`,
    title: 'חוזים וחתימה דיגיטלית',
    desc: 'שלחו חוזה מקצועי עם חתימה דיגיטלית. הלקוח חותם מהנייד — בלי הדפסות וסריקות.',
  },
  {
    icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: 'מעקב תשלומים ופיננסים',
    desc: 'ראו בדיוק מי שילם, מי חייב, ומתי הפקדון הבא. דוחות הכנסה חכמים שיעזרו לכם לצמוח.',
  },
  {
    icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
    title: 'גלריות תמונות ללקוחות',
    desc: 'צרו גלריות מרהיבות ושתפו עם הלקוחות. בחירת תמונות, הגנה בסיסמה, וסנכרון עם Google Drive.',
  },
  {
    icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
    title: 'אוטומציות ותזכורות',
    desc: 'הפסיקו לשכוח. הגדירו אוטומציות לוואטסאפ ומיילים — מעקב אוטומטי, תזכורות לפני אירוע, ועוד.',
  },
];
---

<section id="features" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14 animate-fade-in-up">
      <div class="inline-flex items-center gap-2 bg-brand-gold/10 text-brand-gold px-4 py-1.5 rounded-full text-sm font-medium mb-4">
        הכלים שלכם
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold text-brand-primary mb-4">הכל מה שאתם צריכים לנהל את העסק</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">מערכת אחת שמחליפה עשרות כלים. בנויה בדיוק בשביל ספקי אירועים בישראל.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="group p-6 rounded-2xl border border-gray-100 hover:border-brand-gold/30 hover:shadow-lg transition-all">
          <div class="text-brand-gold mb-4" set:html={feature.icon} />
          <h3 class="text-lg font-bold text-brand-primary mb-2">{feature.title}</h3>
          <p class="text-gray-600 leading-relaxed text-sm">{feature.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

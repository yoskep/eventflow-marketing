---
const stats = [
  { value: 'כל סוגי האירועים', label: 'ניהול מקצה לקצה' },
  { value: '17+', label: 'סוגי ספקים' },
  { value: '50+', label: 'ערים ואזורים' },
  { value: 'CRM חכם', label: 'לספקי אירועים' },
];
---

<section class="py-16 gradient-hero">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">
      {stats.map((stat) => (
        <div class="animate-fade-in">
          <div class="text-4xl font-bold text-brand-gold mb-2">{stat.value}</div>
          <div class="text-gray-300 text-sm">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

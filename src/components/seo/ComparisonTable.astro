---
interface Props { headers: string[]; rows: string[][]; caption?: string; }
const { headers, rows, caption } = Astro.props;
---
<div class="overflow-x-auto mb-8" dir="rtl">
  <table class="w-full text-sm border-collapse">
    {caption && <caption class="text-right text-gray-500 mb-2 text-xs">{caption}</caption>}
    <thead>
      <tr class="bg-brand-primary text-white">
        {headers.map((h) => <th class="px-4 py-3 text-right font-bold">{h}</th>)}
      </tr>
    </thead>
    <tbody>
      {rows.map((row, i) => (
        <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
          {row.map((cell) => <td class="px-4 py-3 border-b border-gray-100">{cell}</td>)}
        </tr>
      ))}
    </tbody>
  </table>
</div>

---
const appUrl = import.meta.env.APP_URL || 'https://app.eventflow.co.il';
---

<div
  id="mobile-cta"
  class="fixed bottom-0 inset-x-0 z-40 md:hidden bg-brand-primary/95 backdrop-blur-sm border-t border-white/10 p-3 transition-transform duration-300"
>
  <a
    href={`${appUrl}/signup`}
    class="gradient-gold text-brand-primary block w-full text-center py-3 rounded-lg font-bold text-base hover:opacity-90 transition-opacity"
    data-track-cta="mobile-sticky"
  >
    התחל בחינם
  </a>
</div>

<script>
  const cta = document.getElementById('mobile-cta');
  const footer = document.querySelector('footer');
  if (cta && footer) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          cta.classList.add('translate-y-full');
        } else {
          cta.classList.remove('translate-y-full');
        }
      },
      { threshold: 0.1 }
    );
    observer.observe(footer);
  }
</script>

---
import type { GetStaticPaths } from 'astro';
import PageLayout from '@/layouts/PageLayout.astro';
import SEOHead from '@/components/seo/SEOHead.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import SupplierCard from '@/components/pseo/SupplierCard.astro';
import CTABlock from '@/components/layout/CTABlock.astro';
import { services, RESERVED_PATHS } from '@/data/services';
import { cities } from '@/data/cities';
import { getAllPublicSuppliers, filterByCity, sortSuppliers } from '@/lib/suppliers';
import { organizationSchema, breadcrumbSchema } from '@/lib/seo';

export const getStaticPaths = (async () => {
  const allSuppliers = await getAllPublicSuppliers();
  return cities.map((city) => {
    const citySuppliers = sortSuppliers(filterByCity(allSuppliers, city.nameHe));
    return {
      params: { city: city.slug },
      props: { city, topSuppliers: citySuppliers.slice(0, 6) },
    };
  });
}) satisfies GetStaticPaths;

const { city, topSuppliers } = Astro.props;
const siteUrl = import.meta.env.SITE_URL || 'https://eventflow.co.il';
const pageUrl = `${siteUrl}/cities/${city.slug}`;

const breadcrumbItems = [
  { name: 'ערים', url: `${siteUrl}/cities` },
  { name: city.nameHe, url: pageUrl },
];

const schemas = [
  organizationSchema(),
  breadcrumbSchema(breadcrumbItems),
];

const activeServices = services.filter((s) => !RESERVED_PATHS.includes(s.slug));
---

<PageLayout>
  <SEOHead
    slot="head"
    title={`ספקי אירועים ב${city.nameHe} | EventFlow`}
    description={`מצאו ספקי אירועים ב${city.nameHe} — צלמים, אולמות, קייטרינג ועוד. השוו מחירים ובחרו את הספק המושלם לאירוע שלכם.`}
    canonical={pageUrl}
    schemas={schemas}
  />

  <section class="gradient-hero py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
      <Breadcrumbs items={breadcrumbItems} />
      <h1 class="text-3xl sm:text-4xl font-bold text-white mt-2">
        ספקי אירועים ב{city.nameHe}
      </h1>
      <p class="mt-3 text-lg text-gray-300 max-w-2xl">
        {city.description}
      </p>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <section>
      <h2 class="mb-4 text-xl font-semibold text-gray-800">
        קטגוריות ספקים ב{city.nameHe}
      </h2>
      <ul class="grid grid-cols-2 gap-2 md:grid-cols-3 lg:grid-cols-4" role="list">
        {activeServices.map((service) => (
          <li>
            <a
              href={`/${service.slug}/${city.slug}`}
              class="block rounded-lg border border-gray-200 px-3 py-2 text-center text-sm font-medium text-gray-700 transition hover:border-brand-gold hover:text-brand-gold"
            >
              {service.nameHe}
            </a>
          </li>
        ))}
      </ul>
    </section>

    {topSuppliers.length > 0 && (
      <section class="mt-12">
        <h2 class="mb-4 text-xl font-semibold text-gray-800">
          ספקים מובילים ב{city.nameHe}
        </h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {topSuppliers.map((supplier) => (
            <SupplierCard supplier={supplier} />
          ))}
        </div>
      </section>
    )}
  </div>

  <CTABlock
    title={`ספק אירועים ב${city.nameHe}?`}
    subtitle="הצטרפו לEventFlow והגיעו ללקוחות שמחפשים ספקים באזורכם"
    buttonText="הוסף את העסק שלך"
    buttonHref="/signup"
    variant="gold"
  />
</PageLayout>

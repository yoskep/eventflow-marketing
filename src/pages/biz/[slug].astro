---
import type { GetStaticPaths } from 'astro';
import PageLayout from '@/layouts/PageLayout.astro';
import SEOHead from '@/components/seo/SEOHead.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import CTABlock from '@/components/layout/CTABlock.astro';
import FreshnessSignal from '@/components/seo/FreshnessSignal.astro';
import { getAllPublicSuppliers } from '@/lib/suppliers';
import { getServiceByDbType } from '@/data/services';
import { organizationSchema, breadcrumbSchema, localBusinessSchema } from '@/lib/seo';

export const getStaticPaths = (async () => {
  const suppliers = await getAllPublicSuppliers();
  return suppliers.map((supplier) => ({
    params: { slug: supplier.slug },
    props: { supplier },
  }));
}) satisfies GetStaticPaths;

const { supplier } = Astro.props;
const siteUrl = import.meta.env.SITE_URL || 'https://eventflow.co.il';
const appUrl = import.meta.env.APP_URL || 'https://app.eventflow.co.il';
const service = getServiceByDbType(supplier.business_type);
const pageUrl = `${siteUrl}/biz/${supplier.slug}`;

const breadcrumbItems = [
  ...(service ? [{ name: service.nameHe, url: `${siteUrl}/${service.slug}` }] : []),
  { name: supplier.business_name, url: pageUrl },
];

const todayDate = new Date().toISOString().split('T')[0];

const schemas = [
  organizationSchema(),
  breadcrumbSchema(breadcrumbItems),
  localBusinessSchema(supplier),
];

const stars = Math.round(supplier.avgRating);
---

<PageLayout>
  <SEOHead
    slot="head"
    title={`${supplier.business_name} | EventFlow`}
    description={supplier.description
      ? supplier.description.slice(0, 155)
      : `${supplier.business_name} — ${service?.nameHe ?? supplier.business_type}${supplier.city ? ` ב${supplier.city}` : ''} | EventFlow`}
    canonical={pageUrl}
    ogType="profile"
    schemas={schemas}
  />

  <section class="gradient-hero py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <Breadcrumbs items={breadcrumbItems} />
      <div class="mt-2 flex items-center gap-4">
        {supplier.logo_url ? (
          <img
            src={supplier.logo_url}
            alt={supplier.business_name}
            width="64"
            height="64"
            class="h-16 w-16 rounded-full object-cover flex-shrink-0 ring-2 ring-white/30"
          />
        ) : (
          <div class="h-16 w-16 rounded-full bg-white/10 flex items-center justify-center flex-shrink-0">
            <span class="text-3xl text-white/60" aria-hidden="true">🏢</span>
          </div>
        )}
        <div>
          <h1 class="text-3xl sm:text-4xl font-bold text-white">
            {supplier.business_name}
          </h1>
          {service && (
            <span class="mt-1 inline-block rounded-full bg-white/20 px-3 py-0.5 text-sm text-white">
              {service.nameHe}
            </span>
          )}
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <FreshnessSignal updatedDate={todayDate} />
    <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
      {supplier.description && (
        <p class="text-gray-700 leading-relaxed">{supplier.description}</p>
      )}

      <dl class="mt-6 space-y-3 text-sm">
        {supplier.city && (
          <div class="flex gap-2">
            <dt class="font-medium text-gray-500 w-20 flex-shrink-0">מיקום</dt>
            <dd class="text-gray-800">{supplier.city}</dd>
          </div>
        )}
        {supplier.phone && (
          <div class="flex gap-2">
            <dt class="font-medium text-gray-500 w-20 flex-shrink-0">טלפון</dt>
            <dd>
              <a href={`tel:${supplier.phone}`} class="text-brand-gold hover:underline">
                {supplier.phone}
              </a>
            </dd>
          </div>
        )}
        {supplier.website_url && (
          <div class="flex gap-2">
            <dt class="font-medium text-gray-500 w-20 flex-shrink-0">אתר</dt>
            <dd>
              <a
                href={supplier.website_url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-brand-gold hover:underline break-all"
              >
                {supplier.website_url}
              </a>
            </dd>
          </div>
        )}
      </dl>

      {supplier.reviewCount > 0 && (
        <div class="mt-6 flex items-center gap-2">
          <span class="flex text-yellow-400 text-lg" aria-label={`דירוג ${supplier.avgRating} מתוך 5`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <span>{i < stars ? '★' : '☆'}</span>
            ))}
          </span>
          <span class="text-sm text-gray-600">
            {supplier.avgRating} ({supplier.reviewCount} ביקורות)
          </span>
        </div>
      )}

      <div class="mt-6">
        <a
          href={`${appUrl}/request-quote/${supplier.slug}`}
          class="inline-block rounded-lg bg-brand-gold px-6 py-3 text-sm font-semibold text-white transition hover:opacity-90"
        >
          בקש הצעת מחיר
        </a>
      </div>
    </div>
  </div>

  <CTABlock
    title="אתם ספקי אירועים?"
    subtitle="הצטרפו לEventFlow ונהלו את העסק שלכם בקלות"
    buttonText="התחילו בחינם"
    buttonHref="/signup"
    variant="primary"
  />
</PageLayout>

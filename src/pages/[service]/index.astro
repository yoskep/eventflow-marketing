---
import type { GetStaticPaths } from 'astro';
import PageLayout from '@/layouts/PageLayout.astro';
import SEOHead from '@/components/seo/SEOHead.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import SupplierCard from '@/components/pseo/SupplierCard.astro';
import CityGrid from '@/components/pseo/CityGrid.astro';
import CTABlock from '@/components/layout/CTABlock.astro';
import { services, RESERVED_PATHS } from '@/data/services';
import { cities } from '@/data/cities';
import { getAllPublicSuppliers, filterByService, sortSuppliers } from '@/lib/suppliers';
import { organizationSchema, breadcrumbSchema } from '@/lib/seo';

export const getStaticPaths = (async () => {
  const allSuppliers = await getAllPublicSuppliers();
  return services
    .filter((s) => !RESERVED_PATHS.includes(s.slug))
    .map((service) => {
      const serviceSuppliers = sortSuppliers(filterByService(allSuppliers, service.dbType));
      return {
        params: { service: service.slug },
        props: { service, topSuppliers: serviceSuppliers.slice(0, 6) },
      };
    });
}) satisfies GetStaticPaths;

const { service, topSuppliers } = Astro.props;
const siteUrl = import.meta.env.SITE_URL || 'https://eventflow.co.il';
const pageUrl = `${siteUrl}/${service.slug}`;

const breadcrumbItems = [
  { name: service.nameHe, url: pageUrl },
];

const schemas = [
  organizationSchema(),
  breadcrumbSchema(breadcrumbItems),
];
---

<PageLayout>
  <SEOHead
    slot="head"
    title={`${service.nameHe} בישראל | EventFlow`}
    description={`מצאו ${service.pluralHe} בכל רחבי ישראל. השוו מחירים, קראו ביקורות ובחרו את הספק המושלם לאירוע שלכם.`}
    canonical={pageUrl}
    schemas={schemas}
  />

  <section class="gradient-hero py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
      <Breadcrumbs items={breadcrumbItems} />
      <h1 class="text-3xl sm:text-4xl font-bold text-white mt-2">
        {service.nameHe} בישראל
      </h1>
      <p class="mt-3 text-lg text-gray-300 max-w-2xl">
        {service.descriptionHe} — מצאו את הספק המושלם לאירוע שלכם בכל רחבי הארץ.
      </p>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <section>
      <h2 class="mb-4 text-xl font-semibold text-gray-800">
        בחרו עיר למציאת {service.pluralHe}
      </h2>
      <CityGrid cities={cities} serviceSlug={service.slug} />
    </section>

    {topSuppliers.length > 0 && (
      <section class="mt-12">
        <h2 class="mb-4 text-xl font-semibold text-gray-800">
          {service.pluralHe} מובילים
        </h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {topSuppliers.map((supplier) => (
            <SupplierCard supplier={supplier} />
          ))}
        </div>
      </section>
    )}
  </div>

  <CTABlock
    title={`אתם ${service.pluralHe}?`}
    subtitle="הצטרפו לEventFlow ותגיעו ללקוחות שמחפשים את השירות שלכם"
    buttonText="הוסף את העסק שלך"
    buttonHref="/signup"
    variant="gold"
  />
</PageLayout>
